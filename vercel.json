{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://www.youtube.com https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; media-src 'self' https:; frame-src https://www.youtube.com https://www.google.com; connect-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },

    { "source": "/pir-panels", "destination": "/services/pir-sandwich-panels", "permanent": true },
    { "source": "/pir-panels/:rest*", "destination": "/services/pir-sandwich-panels", "permanent": true },
    { "source": "/eps-panels", "destination": "/services/pir-sandwich-panels", "permanent": true },
    { "source": "/eps-panels/:rest*", "destination": "/services/pir-sandwich-panels", "permanent": true },

    { "source": "/cold-stores", "destination": "/services/cold-stores", "permanent": true },
    { "source": "/cold-stores/pharmaceutical-cold-storage-solutions", "destination": "/services/cold-stores", "permanent": true },
    { "source": "/cold-stores/meat-and-poultry-cold-storage-services", "destination": "/services/cold-stores", "permanent": true },
    { "source": "/cold-stores/fruits-and-vegetables-cold-storages", "destination": "/services/cold-stores", "permanent": true },
    { "source": "/cold-stores/potato-and-onion-cold-room", "destination": "/services/cold-stores", "permanent": true },
    { "source": "/cold-stores/:rest*", "destination": "/services/cold-stores", "permanent": true },

    { "source": "/ca-stores", "destination": "/services/ca-stores", "permanent": true },
    { "source": "/ca-stores/:rest*", "destination": "/services/ca-stores", "permanent": true },

    { "source": "/prefabmodular-solutions", "destination": "/services/prefabricated-structures", "permanent": true },
    { "source": "/prefabmodular-solutions/:rest*", "destination": "/services/prefabricated-structures", "permanent": true },
    { "source": "/prefabricated-structures-pakistan", "destination": "/services/prefabricated-structures", "permanent": true },

    { "source": "/refrigeration", "destination": "/services/refrigeration-systems", "permanent": true },
    { "source": "/refrigeration-systems", "destination": "/services/refrigeration-systems", "permanent": true },
    { "source": "/insulated-doors", "destination": "/services/insulated-doors", "permanent": true },

    { "source": "/about-izhar", "destination": "/about", "permanent": true },
    { "source": "/about-us", "destination": "/about", "permanent": true },
    { "source": "/contact-us", "destination": "/contact", "permanent": true },

    { "source": "/blogs", "destination": "/blog", "permanent": true },
    { "source": "/blogs/what-is-cold-storage-advantage-of-cold-storage-in-food-and-pharmaceutical-industry", "destination": "/blog/cold-storage-solutions-pakistan-demand-rising", "permanent": true },
    { "source": "/blogs/what-is-cold-chain-importance-and-advantages-of-cold-chain-in-food-and-pharma-industry", "destination": "/blog/cold-storage-pakistan-export-growth", "permanent": true },
    { "source": "/blogs/:rest*", "destination": "/blog", "permanent": true },

    { "source": "/uncategorized/what-is-a-blast-freezer-advantages-of-blast-freezer", "destination": "/blog/refrigeration-systems-cold-chain-pakistan", "permanent": true },
    { "source": "/uncategorized/cold-storage-cost-in-pakistan", "destination": "/blog/cold-storage-solutions-pakistan-demand-rising", "permanent": true },
    { "source": "/uncategorized/:rest*", "destination": "/blog", "permanent": true },

    { "source": "/top-5-cold-storage-facilities-in-lahore-features-tips", "destination": "/blog/cold-storage-solutions-pakistan-demand-rising", "permanent": true },
    { "source": "/blog/top-7-applications-of-pir-sandwich-panels-in-industry", "destination": "/blog/pir-panels-thermal-efficiency-smart-building", "permanent": true }
  ]
}
